# =========================
# Execution & Temporary Files
# =========================
# Ignore the temporary folders where the worker saves user code before passing to Docker
temp/
tmp/
/worker/temp/
/worker/submissions/
*.class
*.exe
*.o

# =========================
# Docker & Database Data
# =========================
# Ignore local database/queue storage if you map Docker volumes locally
pgdata/
redisdata/
rabbitmqdata/
data/

# =========================
# IDE & OS Files
# =========================
.vscode/
.idea/
.DS_Store
Thumbs.db