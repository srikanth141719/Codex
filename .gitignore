# =========================
# Node Dependencies
# (This single rule ignores node_modules in frontend/, backend/, and worker/)
# =========================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =========================
# Environment Variables (CRITICAL)
# =========================
.env
.env.*
!.env.example

# =========================
# Frontend Build Outputs
# =========================
frontend/dist/
frontend/build/
.next/

# =========================
# Worker / Execution Temp Files
# (Prevents user submissions and compiled binaries from being committed)
# =========================
worker/temp/
worker/tmp/
worker/submissions/
*.class
*.exe
*.out
*.o

# =========================
# Database & Infrastructure Volumes
# (Assuming your docker-compose maps data to the ./db folder or root)
# =========================
db/data/
pgdata/
redisdata/
rabbitmqdata/

# =========================
# IDE & OS Files
# =========================
.vscode/
.idea/
.DS_Store
Thumbs.db